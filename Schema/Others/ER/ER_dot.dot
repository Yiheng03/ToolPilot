digraph G {
graph [rankdir=LR, splines=ortho, overlap=false, nodesep=0.55, ranksep=1.0, bgcolor="white", fontname="Noto Sans CJK SC", label=<<B>BladeWise刀具报价｜Schema ER 技术图</B><BR/><FONT POINT-SIZE="14">PostgreSQL schema: blade_quote（含主键、外键、核心约束关系）</FONT>>, labelloc=t, fontsize=26];
node [shape=plain, fontname="Noto Sans CJK SC"];
edge [fontname="Noto Sans CJK SC", fontsize=10, color="#6B7280", arrowsize=0.7];
